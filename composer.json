{
    "scripts": {
        "test": [
            "@test:phpunit",
            "@test:behat"
        ],
        "test:phpunit": "vendor/bin/phpunit",
        "test:behat": "vendor/bin/behat --strict"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "behat/behat": "^3.15"
    },
    "autoload": {
        "psr-4": {
            "Src\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
